<%- include('partials/header', { title: activeCategory ? activeCategory : '全部产品' }) %>

<section class="products-page">
  <div class="container">
    <h2 class="section-title"><%= activeCategory || '全部产品' %></h2>

    <div class="category-filter">
      <a href="/products" class="filter-tag <%= !activeCategory ? 'active' : '' %>">全部</a>
      <% categories.forEach(cat => { %>
      <a href="/products?category=<%= encodeURIComponent(cat) %>" class="filter-tag <%= activeCategory === cat ? 'active' : '' %>"><%= cat %></a>
      <% }) %>
    </div>

    <% if (products.length === 0) { %>
    <p class="empty-msg">该分类暂无产品</p>
    <% } else { %>
    <div class="product-grid">
      <% products.forEach(p => { %>
      <div class="product-card">
        <a href="/product/<%= p.id %>">
          <div class="product-image">
            <div class="img-placeholder" data-cat="<%= p.category %>">
              <span class="img-label"><%= p.category %></span>
            </div>
            <% if (p.original_price > p.price) { %>
            <span class="badge-sale">优惠</span>
            <% } %>
          </div>
          <div class="product-info">
            <h3><%= p.name %></h3>
            <p class="product-desc"><%= p.description %></p>
            <div class="product-price">
              <span class="price-current">¥<%= p.price.toLocaleString() %></span>
              <% if (p.original_price > p.price) { %>
              <span class="price-original">¥<%= p.original_price.toLocaleString() %></span>
              <% } %>
            </div>
          </div>
        </a>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
